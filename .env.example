# Your API keys go here - DO NOT commit this file to Git!
# Copy this file to .env and add your actual API keys

# Required API Keys
OPENAI_API_KEY=your_openai_api_key_here
ELEVEN_API_KEY=your_elevenlabs_api_key_here

# Optional Future APIs
LEONARDO_API_KEY=your_leonardo_api_key_here
PICTORY_API_KEY=your_pictory_api_key_here

# Stock Video APIs (Free)
PEXELS_API_KEY=your_pexels_api_key_here
UNSPLASH_ACCESS_KEY=your_unsplash_key_here

# AI Video Generation
RUNWAY_API_KEY=your_runway_api_key_here
PIKA_API_KEY=your_pika_api_key_here

# Video Settings (Optional - good defaults provided)
OUTPUT_RESOLUTION=1080x1920
TARGET_DURATION=60
SCRIPT_WORD_COUNT=130-160

# ElevenLabs Voice Settings (Optional - good defaults provided)
ELEVEN_VOICE_ID=EXAVITQu4vr4xnSDxMaL
ELEVEN_MODEL=eleven_multilingual_v2
