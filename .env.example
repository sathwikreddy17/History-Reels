# Reels Factory — environment configuration
# Copy this to .env and fill in your values.

# ── API Keys ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here       # Only needed if SCRIPT_BACKEND=openai
ELEVEN_API_KEY=your_elevenlabs_api_key_here   # Only needed if TTS_BACKEND=elevenlabs

# ── Script generation ─────────────────────────────────────────────────────────
# "local"  → LM Studio running on your Mac (free, offline, recommended)
# "openai" → OpenAI API cloud (costs money, good fallback)
SCRIPT_BACKEND=local

# LM Studio settings (only used when SCRIPT_BACKEND=local)
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=yi-1.5-34b-chat

# Script word count target (130-150 words ≈ 55-65 second voiceover)
SCRIPT_MIN_WORDS=130
SCRIPT_MAX_WORDS=150

# ── Voiceover / TTS ───────────────────────────────────────────────────────────
# "elevenlabs" → ElevenLabs cloud API (best quality)
# "kokoro"     → local Kokoro model (free, works offline)
TTS_BACKEND=elevenlabs

# ElevenLabs voice selection
# onwK4e9ZLuTAKqWW03F9 = Daniel (British, dramatic) ← recommended
# pNInz6obpgDQGcFmaJgB = Adam  (American, authoritative)
# ErXwobaYiN019PkySvjV = Antoni (warm, narrator-style)
ELEVEN_VOICE_ID=onwK4e9ZLuTAKqWW03F9
ELEVEN_MODEL=eleven_multilingual_v2
ELEVEN_STABILITY=0.45
ELEVEN_SIMILARITY=0.85
ELEVEN_STYLE=0.40

# Kokoro local TTS (only used when TTS_BACKEND=kokoro)
KOKORO_VOICE=am_michael
KOKORO_SPEED=1.0

# ── Captions ─────────────────────────────────────────────────────────────────
CAPTIONS_ENABLED=true
CAPTION_FONT_SIZE=72
CAPTION_WORDS_PER_CARD=3
CAPTION_Y_POSITION=0.82
